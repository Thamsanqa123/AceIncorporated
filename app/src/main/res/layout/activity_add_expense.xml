<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg_dark"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:src="@drawable/ace_logo"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:alpha="0.05"
        android:scaleType="centerInside"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Add Expense"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_button"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- TITLE -->
                <EditText
                    android:id="@+id/titleInput"
                    android:hint="Expense Title"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- AMOUNT -->
                <EditText
                    android:id="@+id/amountInput"
                    android:hint="Amount (R)"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- CATEGORY (for DB) -->
                <EditText
                    android:id="@+id/categoryInput"
                    android:hint="Category"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- OPTIONAL EXTRA DESCRIPTION -->
                <EditText
                    android:id="@+id/description"
                    android:hint="Extra Description"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- DATE -->
                <Button
                    android:id="@+id/dateBtn"
                    android:text="Select Date"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- TIME -->
                <Button
                    android:id="@+id/startTimeBtn"
                    android:text="Start Time"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/endTimeBtn"
                    android:text="End Time"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- SPINNER (optional UI only) -->
                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- IMAGE -->
                <Button
                    android:id="@+id/uploadImageBtn"
                    android:text="Upload Receipt"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:id="@+id/previewImage"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="10dp"
                    android:scaleType="centerCrop"/>

                <!-- SAVE -->
                <Button
                    android:id="@+id/saveBtn"
                    android:text="Save Expense"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>