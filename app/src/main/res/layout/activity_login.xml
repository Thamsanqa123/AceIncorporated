<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Glow Background -->
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_gravity="center"
        android:background="@drawable/glow_circle"
        android:alpha="0.12"/>

    <!-- Background Logo -->
    <ImageView
        android:src="@drawable/ace_logo"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:alpha="0.04"
        android:scaleType="centerInside"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Logo -->

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="25dp"
                android:src="@drawable/ace_logo"/>

            <!-- App Name -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACE INCORPORATED"
                android:textColor="@color/purple_light"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <!-- Welcome -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Let’s get you back in control"
                android:textColor="@color/text_fade"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <!-- Login Card -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@drawable/glass_button"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Username -->

                <EditText
                    android:id="@+id/username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Username"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:backgroundTint="@color/purple_light"/>

                <!-- Password -->

                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_fade"
                    android:backgroundTint="@color/purple_light"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secure login protected by ACE"
                    android:textColor="@color/text_fade"
                    android:textSize="12sp"
                    android:layout_marginTop="5dp"/>

                <!-- Sign In -->

                <Button
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="25dp"
                    android:text="Sign In"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"/>

                <!-- Create Account -->

                <Button
                    android:id="@+id/signupBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="10dp"
                    android:text="Create Account"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:background="@drawable/glass_button"/>

            </LinearLayout>

            <!-- Footer -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 Your financial data stays private"
                android:textColor="@color/text_fade"
                android:textSize="13sp"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track • Save • Grow"
                android:textColor="@color/purple_light"
                android:textSize="13sp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </ScrollView>

</FrameLayout>